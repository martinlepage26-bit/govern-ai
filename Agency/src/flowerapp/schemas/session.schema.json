{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["app_version", "session_schema_version", "metadata", "intake", "scoring"],
  "properties": {
    "app_version": { "type": "string" },
    "session_schema_version": { "type": "integer" },
    "metadata": { "type": "object", "required": ["project_id", "project_name"] },
    "intake": {
      "type": "object",
      "patternProperties": {
        ".*": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["value", "tier"],
            "properties": {
              "value": { "type": "string" },
              "tier": { "enum": ["A", "B", "C"] }
            }
          }
        }
      }
    },
    "scoring": {
      "type": "object",
      "required": ["agency_total", "subscores"]
    }
  }
}
